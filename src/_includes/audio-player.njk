{# ============================================================
   MAVEL'S CORNER — AUDIO PLAYER PARTIAL
   File: src/_includes/audio-player.njk
   v3.0 — Draggable progress, gender toggle, volume, keyboard, resume prompt
   ============================================================ #}

<!-- ── AUDIO PLAYER CSS ── -->
<link rel="stylesheet" href="/assets/css/audio-player.css">

<!-- ── FAB TRIGGER BUTTON ── -->
<button
  id="mc-audio-trigger"
  aria-label="Open read aloud player"
  aria-expanded="false"
  aria-controls="mc-audio-player"
  title="Listen to this post"
>
  <span class="ap-fab-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M12 3C7.03 3 3 7.03 3 12v5a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H5v-1a7 7 0 0 1 14 0v1h-1a2 2 0 0 0-2 2v3a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-5c0-4.97-4.03-9-9-9z"/>
    </svg>
  </span>
  <span class="ap-fab-label" id="ap-fab-label">Listen</span>
</button>

<!-- ── FLOATING PLAYER PANEL ── -->
<div
  id="mc-audio-player"
  role="region"
  aria-label="Read aloud audio player"
  aria-live="polite"
>

  <!-- Resume prompt banner -->
  <div class="ap-resume-prompt" id="ap-resume-prompt" aria-live="polite">
    <span class="ap-resume-text" id="ap-resume-text">Resume where you left off?</span>
    <div class="ap-resume-btns">
      <button class="ap-resume-btn ap-resume-yes" id="ap-resume-yes">Resume</button>
      <button class="ap-resume-btn ap-resume-no"  id="ap-resume-no">Start Over</button>
    </div>
  </div>

  <!-- Header -->
  <div class="ap-header">
    <div class="ap-icon-wrap" aria-hidden="true">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <rect x="2"  y="9"  width="2" height="6" rx="1"/>
        <rect x="6"  y="6"  width="2" height="12" rx="1"/>
        <rect x="10" y="3"  width="2" height="18" rx="1"/>
        <rect x="14" y="6"  width="2" height="12" rx="1"/>
        <rect x="18" y="9"  width="2" height="6"  rx="1"/>
      </svg>
    </div>
    <div class="ap-meta">
      <div class="ap-label">Now Reading</div>
      <div class="ap-title" id="ap-post-title">{{ title if title else "This Post" }}</div>
      <div class="ap-author">by Emmanuel &mdash; Mavel's Corner</div>
    </div>
    <button class="ap-close" id="ap-close" aria-label="Close player">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <line x1="18" y1="6" x2="6" y2="18"/>
        <line x1="6"  y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <!-- Waveform visualiser -->
  <div class="ap-wave" id="ap-wave" aria-hidden="true">
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
    <div class="ap-wave-bar"></div>
  </div>

  <!-- Progress scrubber -->
  <div class="ap-progress-wrap">
    <div
      class="ap-progress-track"
      id="ap-progress-track"
      role="slider"
      aria-label="Reading progress"
      aria-valuemin="0"
      aria-valuemax="100"
      aria-valuenow="0"
      tabindex="0"
    >
      <div class="ap-progress-fill ap-smooth" id="ap-progress-fill"></div>
      <div class="ap-progress-thumb" id="ap-progress-thumb"></div>
    </div>
    <div class="ap-time-row">
      <span id="ap-time-elapsed">0:00</span>
      <span id="ap-time-duration">--:--</span>
    </div>
  </div>

  <!-- Controls -->
  <div class="ap-controls">
    <!-- Stop -->
    <button class="ap-btn-icon" id="ap-btn-stop" aria-label="Stop">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <rect x="4" y="4" width="16" height="16" rx="2"/>
      </svg>
    </button>

    <!-- Play / Pause -->
    <button class="ap-btn-play" id="ap-btn-play" aria-label="Play">
      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
        <polygon points="5,3 19,12 5,21"/>
      </svg>
    </button>

    <!-- Speed -->
    <button class="ap-speed-btn"          data-rate="0.8"  aria-label="Speed 0.8x">0.8x</button>
    <button class="ap-speed-btn ap-active" data-rate="1"    aria-label="Speed 1x">1x</button>
    <button class="ap-speed-btn"          data-rate="1.25" aria-label="Speed 1.25x">1.25x</button>
    <button class="ap-speed-btn"          data-rate="1.5"  aria-label="Speed 1.5x">1.5x</button>
  </div>

  <!-- Volume row -->
  <div class="ap-volume-row">
    <!-- Speaker icon -->
    <svg class="ap-volume-icon" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3A4.5 4.5 0 0 0 14 7.97v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>
    </svg>
    <input
      type="range"
      class="ap-volume-slider"
      id="ap-volume-slider"
      min="0"
      max="100"
      value="100"
      aria-label="Volume"
      step="1"
    >
    <span class="ap-volume-pct" id="ap-volume-pct">100%</span>
  </div>

  <!-- Voice row: gender toggle + secondary dropdown -->
  <div class="ap-voice-row">
    <span class="ap-voice-label">Voice</span>

    <!-- Gender toggle -->
    <div class="ap-gender-toggle" role="group" aria-label="Voice gender">
      <button class="ap-gender-btn ap-active" data-gender="female" aria-pressed="true">
        <!-- Female symbol -->
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="12" cy="9" r="5" fill="none" stroke="currentColor" stroke-width="2"/>
          <line x1="12" y1="14" x2="12" y2="20" stroke="currentColor" stroke-width="2"/>
          <line x1="9"  y1="17" x2="15" y2="17" stroke="currentColor" stroke-width="2"/>
        </svg>
        Female
      </button>
      <button class="ap-gender-btn" data-gender="male" aria-pressed="false">
        <!-- Male symbol -->
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <circle cx="10" cy="14" r="5" fill="none" stroke="currentColor" stroke-width="2"/>
          <line x1="14.5" y1="9.5" x2="20" y2="4" stroke="currentColor" stroke-width="2"/>
          <polyline points="15,4 20,4 20,9" fill="none" stroke="currentColor" stroke-width="2"/>
        </svg>
        Male
      </button>
    </div>

    <!-- Secondary voice dropdown -->
    <select class="ap-voice-select" id="ap-voice-select" aria-label="Select specific voice">
      <option>Loading voices...</option>
    </select>
  </div>

  <!-- Status footer -->
  <div class="ap-footer">
    <span class="ap-status" id="ap-status">Tap play to listen to this post.</span>
    <span class="ap-kb-hint" aria-hidden="true">Space to play &middot; &larr;&rarr; to skip</span>
  </div>

</div>

<!-- Silent keep-alive audio (Android screen lock fix) -->
<audio id="ap-silent-audio" loop aria-hidden="true" style="display:none" preload="none"></audio>

<!-- ── AUDIO PLAYER SCRIPT ── -->
<script src="/assets/js/audio-player.js" defer></script>
