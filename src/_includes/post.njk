<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ title }} | Mavel's Corner</title>
  <meta name="description" content="{{ excerpt }}"/>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500;1,600&family=Lato:ital,wght@0,300;0,400;0,700;1,300;1,400&display=swap" rel="stylesheet">
  <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
  <style>
    :root{
      --teal:#1B9AAA;--teal-light:#22b8cc;--teal-dark:#157a87;
      --white:#FFFFFF;--navy:#0D2B30;--navy-light:#163b42;
      --gold:#C8973A;--gold-light:#d9ac55;--cream:#FBF8F3;
      --text-dark:#1a1a2e;--text-mid:#3d4f52;--text-light:#6b7c7f;
      --border:rgba(27,154,170,0.15);
      --shadow-sm:0 2px 12px rgba(13,43,48,0.08);
      --shadow-md:0 8px 32px rgba(13,43,48,0.12);
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    html{scroll-behavior:smooth;font-size:16px}
    body{font-family:'Lato',sans-serif;color:var(--text-dark);background:var(--cream);line-height:1.7}
    h1,h2,h3,h4{font-family:'Playfair Display',serif;line-height:1.25}

    nav{position:fixed;top:0;left:0;right:0;z-index:999;background:rgba(13,43,48,0.97);backdrop-filter:blur(12px);border-bottom:1px solid rgba(200,151,58,0.2);padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:68px}
    .nav-brand{font-family:'Playfair Display',serif;font-size:1.25rem;font-weight:700;color:var(--white);text-decoration:none}
    .nav-brand span{color:var(--gold)}
    .nav-links{display:flex;align-items:center;gap:0.25rem;list-style:none}
    .nav-links a{display:block;padding:0.45rem 0.85rem;color:rgba(255,255,255,0.75);text-decoration:none;font-size:0.875rem;font-weight:400;letter-spacing:0.04em;text-transform:uppercase;border-radius:4px;transition:color 0.2s,background 0.2s}
    .nav-links a:hover{color:var(--white);background:rgba(255,255,255,0.08)}
    .nav-links a.active{color:var(--gold);background:rgba(200,151,58,0.12)}
    .hamburger{display:none;flex-direction:column;gap:5px;cursor:pointer;padding:4px;background:none;border:none}
    .hamburger span{display:block;width:24px;height:2px;background:var(--white);border-radius:2px}
    .mobile-menu{display:none;position:fixed;top:68px;left:0;right:0;background:var(--navy);padding:1.5rem 2rem;z-index:998;border-bottom:2px solid var(--gold);flex-direction:column;gap:0.5rem}
    .mobile-menu.open{display:flex}
    .mobile-menu a{color:rgba(255,255,255,0.8);text-decoration:none;font-size:1rem;letter-spacing:0.05em;text-transform:uppercase;padding:0.75rem 0;border-bottom:1px solid rgba(255,255,255,0.08)}
    .mobile-menu a:hover{color:var(--gold)}
    @media(max-width:700px){.nav-links{display:none}.hamburger{display:flex}}

    /* ── POST HERO ── */
    .post-page-hero{background:var(--navy);padding:7rem 2rem 5rem;position:relative;overflow:hidden}
    .post-page-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 60% at 20% 50%,rgba(27,154,170,0.14) 0%,transparent 60%),radial-gradient(ellipse 40% 50% at 80% 30%,rgba(200,151,58,0.08) 0%,transparent 55%)}
    .post-page-hero-inner{max-width:780px;margin:0 auto;position:relative}
    .post-back-btn{display:inline-flex;align-items:center;gap:0.5rem;color:rgba(255,255,255,0.5);font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;margin-bottom:2rem;transition:color 0.2s}
    .post-back-btn:hover{color:var(--teal-light)}
    .post-meta-row{display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;flex-wrap:wrap}
    .post-category{display:inline-block;font-size:0.65rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:var(--teal);background:rgba(27,154,170,0.1);padding:0.25rem 0.65rem;border-radius:2px}
    .post-meta-date{font-size:0.75rem;color:rgba(255,255,255,0.4);letter-spacing:0.08em}
    .post-page-hero h1{font-size:clamp(1.9rem,4.5vw,3.2rem);color:var(--white);font-weight:800;line-height:1.15;margin-bottom:1rem}
    .post-subtitle{font-size:1.1rem;color:rgba(255,255,255,0.6);font-style:italic;font-family:'Playfair Display',serif;line-height:1.7}

    /* ── ARTICLE ── */
    .article-body{background:var(--white);padding:4rem 2rem 5rem}
    .article-inner{max-width:720px;margin:0 auto}
    .article-inner p{font-size:1.05rem;color:var(--text-mid);line-height:1.95;margin-bottom:1.65rem}
    .article-inner h2{font-size:1.55rem;color:var(--navy);margin:2.75rem 0 1.1rem;font-weight:700}
    .article-inner strong{color:var(--navy);font-weight:700}
    .article-inner em{font-style:italic}
    .article-inner ul,.article-inner ol{margin:1rem 0 1.5rem 1.5rem}
    .article-inner li{font-size:1rem;color:var(--text-mid);line-height:1.8;margin-bottom:0.4rem}
    .article-inner hr{border:none;border-top:1px solid var(--border);margin:3rem 0}

    /* Blockquotes become scripture blocks */
    .article-inner blockquote{border-left:3px solid var(--gold);background:rgba(200,151,58,0.06);border-radius:0 8px 8px 0;padding:1.5rem 2rem;margin:2.25rem 0}
    .article-inner blockquote p{font-family:'Playfair Display',serif;font-style:italic;font-size:1.05rem;color:var(--navy);line-height:1.7;margin-bottom:0.5rem}
    .article-inner blockquote p:last-child{font-size:0.8rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--gold);font-style:normal;font-family:'Lato',sans-serif;margin-bottom:0}

    /* Tags */
    .post-tags{display:flex;flex-wrap:wrap;gap:0.4rem;margin-bottom:2rem}
    .tag-chip{font-size:0.65rem;background:rgba(27,154,170,0.08);color:var(--teal);border:1px solid rgba(27,154,170,0.2);padding:0.2rem 0.55rem;border-radius:2px}

    /* Share row */
    .article-share{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;padding-top:2rem;border-top:1px solid var(--border)}
    .article-share p{font-size:0.85rem;color:var(--text-light);font-style:italic;margin:0}
    .btn{display:inline-block;padding:0.65rem 1.4rem;border-radius:4px;font-family:'Lato',sans-serif;font-size:0.8rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;cursor:pointer;border:none;text-decoration:none;transition:all 0.25s}
    .btn-primary{background:var(--teal);color:var(--white)}
    .btn-primary:hover{background:var(--teal-dark);transform:translateY(-2px)}
    .share-btn{background:transparent;border:1.5px solid var(--border);color:var(--text-mid);font-family:'Lato',sans-serif;font-size:0.75rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:0.5rem 1rem;border-radius:4px;cursor:pointer;transition:all 0.2s}
    .share-btn:hover{background:var(--teal);border-color:var(--teal);color:var(--white)}

    /* Related posts */
    .related-section{background:var(--cream);padding:4rem 2rem}
    .related-inner{max-width:1100px;margin:0 auto}
    .related-inner h3{font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--navy);margin-bottom:2rem;text-align:center}
    .related-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:1.5rem}
    .related-card{background:var(--white);border-radius:8px;padding:1.5rem;border:1px solid var(--border);text-decoration:none;display:block;transition:all 0.2s}
    .related-card:hover{border-color:var(--teal);transform:translateY(-3px);box-shadow:var(--shadow-sm)}
    .related-card .post-category{margin-bottom:0.6rem;display:block}
    .related-card h4{font-family:'Playfair Display',serif;font-size:1.05rem;color:var(--navy);line-height:1.3;margin-bottom:0.4rem}
    .related-card .scripture{font-size:0.8rem;color:var(--gold);font-style:italic}

    footer{background:#070f11;padding:3.5rem 2rem 2rem;color:rgba(255,255,255,0.5);font-size:0.875rem}
    .footer-inner{max-width:1100px;margin:0 auto}
    .footer-top{display:grid;grid-template-columns:1.5fr repeat(3,1fr);gap:2.5rem;margin-bottom:3rem;padding-bottom:3rem;border-bottom:1px solid rgba(255,255,255,0.07)}
    @media(max-width:900px){.footer-top{grid-template-columns:1fr 1fr}}
    @media(max-width:600px){.footer-top{grid-template-columns:1fr}}
    .footer-brand h3{font-family:'Playfair Display',serif;color:var(--white);font-size:1.2rem;margin-bottom:0.75rem}
    .footer-brand h3 span{color:var(--gold)}
    .footer-brand p{font-style:italic;color:rgba(255,255,255,0.4);font-size:0.85rem;line-height:1.8;margin-bottom:1.25rem}
    .footer-teal-line{width:40px;height:2px;background:var(--teal)}
    .footer-col h4{font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.6);margin-bottom:1.25rem}
    .footer-col ul{list-style:none}
    .footer-col ul li{margin-bottom:0.6rem}
    .footer-col ul li a{color:rgba(255,255,255,0.4);text-decoration:none;font-size:0.875rem;transition:color 0.2s}
    .footer-col ul li a:hover{color:var(--teal-light)}
    .footer-bottom{display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:1rem;font-size:0.8rem}

    @keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
    .article-inner{animation:fadeUp 0.8s ease forwards}

    /* ── MavelogxDigital Credit ── */
    @keyframes mavelog-sweep{0%{background-position:0% 50%}100%{background-position:200% 50%}}
    .mavelog-credit{text-decoration:none;opacity:.8;transition:opacity .25s ease;font-size:.8rem;color:rgba(255,255,255,.5)}
    .mavelog-credit:hover{opacity:1}
    .mavelog-brand{font-weight:700;background:linear-gradient(90deg,#E85C6E,#F5A825,#7070BB,#3BBFA0,#4A9DC4,#F47820,#E85C6E);background-size:200% auto;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;animation:mavelog-sweep 4s linear infinite}
  </style>
</head>
<body>

<nav id="mainNav">
  <a href="/" class="nav-brand">Mavel's <span>Corner</span></a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/#about">About</a></li>
    <li><a href="/blog/" class="active">Blog</a></li>
    <li><a href="/#prayer">Prayer</a></li>
    <li><a href="/#contact">Contact</a></li>
  </ul>
  <button class="hamburger" id="hamburger" onclick="document.getElementById('mobileMenu').classList.toggle('open')" aria-label="Menu">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="/">Home</a>
  <a href="/#about">About</a>
  <a href="/blog/" class="active">Blog</a>
  <a href="/#prayer">Prayer</a>
  <a href="/#contact">Contact</a>
</div>

<!-- POST HERO -->
<section class="post-page-hero">
  <div class="post-page-hero-inner">
    <a href="/blog/" class="post-back-btn">← Back to Blog</a>
    <div class="post-meta-row">
      <span class="post-category">{{ category }}</span>
      <span class="post-meta-date">{{ date | readableDate }}</span>
    </div>
    <h1>{{ title }}</h1>
    {% if subtitle %}<p class="post-subtitle">{{ subtitle }}</p>{% endif %}
  </div>
</section>

<!-- ARTICLE BODY -->
<article class="article-body">
  <div class="article-inner">

    {% if tags %}
    <div class="post-tags">
      {% for tag in tags %}
        {% if tag != "post" %}
          <span class="tag-chip">#{{ tag }}</span>
        {% endif %}
      {% endfor %}
    </div>
    {% endif %}

    {{ content | safe }}

    <hr>

    <div class="article-share">
      <p>Share this post with someone who needs to hear it today.</p>
      <div style="display:flex;gap:0.5rem;flex-wrap:wrap">
        <button class="share-btn" onclick="shareTwitter()">Share on X</button>
        <button class="share-btn" onclick="shareFacebook()">Share on Facebook</button>
        <button class="share-btn" onclick="copyLink()">Copy Link</button>
        <a href="/#prayer" class="btn btn-primary">Submit a Prayer Request →</a>
      </div>
    </div>

  </div>
</article>

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-brand">
        <h3>Mavel's <span>Corner</span></h3>
        <p>Hope for the broken. Truth for the searching. Grace for the waiting.</p>
        <div class="footer-teal-line"></div>
      </div>
      <div class="footer-col">
        <h4>Navigate</h4>
        <ul>
          <li><a href="/">Home</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/blog/">Blog</a></li>
          <li><a href="/#prayer">Prayer Request</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Support</h4>
        <ul><li><a href="/#contact">Contact</a></li></ul>
      </div>
      <div class="footer-col">
        <h4>Categories</h4>
        <ul>
          <li><a href="/blog/">Faith &amp; Discipleship</a></li>
          <li><a href="/blog/">Christian Living</a></li>
        </ul>
      </div>
    </div>
    <div class="footer-bottom">
      <span>© 2026 Mavel's Corner. All rights reserved.</span>
      <a href="https://mavelogxdigital.com/" target="_blank" rel="noopener noreferrer" class="mavelog-credit">Website designed by <span class="mavelog-brand">MavelogxDigital</span></a>
    </div>
  </div>
</footer>

<script>
  window.addEventListener('scroll',()=>{
    document.getElementById('mainNav').classList.toggle('scrolled',window.scrollY>20)
  });
  function shareTwitter(){
    window.open('https://twitter.com/intent/tweet?url='+encodeURIComponent(location.href)+'&text='+encodeURIComponent('{{ title }} | Mavel\'s Corner'),'_blank');
  }
  function shareFacebook(){
    window.open('https://www.facebook.com/sharer/sharer.php?u='+encodeURIComponent(location.href),'_blank');
  }
  function copyLink(){
    navigator.clipboard.writeText(location.href).then(()=>{
      event.target.textContent='Copied!';
      setTimeout(()=>event.target.textContent='Copy Link',2000);
    });
  }
</script>

</body>
</html>
