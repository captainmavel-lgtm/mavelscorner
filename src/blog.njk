<script>
  function toggleMenu(){document.getElementById('mobileMenu').classList.toggle('open')}
  window.addEventListener('scroll',()=>{document.getElementById('mainNav').classList.toggle('scrolled',window.scrollY>20)})

  // Navigate back to SPA pages
  function goSPA(page){
    sessionStorage.setItem('mavelPage', page);
  }

  function filterPosts(category, btn){
    document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
    btn.classList.add('active');
    const featured = document.getElementById('featuredWrap');
    const cards = document.querySelectorAll('#postsGrid .post-card');
    if(category==='all'){
      if(featured) featured.style.display='';
      cards.forEach(c=>c.style.display='');
    } else {
      if(featured) featured.style.display = featured.dataset.category===category ? '' : 'none';
      cards.forEach(c=>c.style.display = c.dataset.category===category ? '' : 'none');
    }
  }
</script>

